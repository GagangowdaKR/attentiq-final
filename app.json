{
  "expo": {
    "name": "Attentiq",
    "slug": "attentiq",
    "version": "1.0.0",
    "scheme": "attentiq",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attentiq.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is required for meeting and attention monitoring.",
        "NSMicrophoneUsageDescription": "Microphone is required for meeting audio."
      }
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#0A0A0F" },
      "package": "com.attentiq.app",
      "permissions": ["CAMERA", "RECORD_AUDIO", "INTERNET"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      ["expo-av", { "microphonePermission": "Allow Attentiq to access your microphone." }]
    ]
  }
}
